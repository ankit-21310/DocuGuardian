# =========================
# Frontend
# =========================
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# =========================
# Local Storage
# =========================
DOCUGUARDIAN_DATA_DIR=./data

# =========================
# CORS
# =========================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# =========================
# Environment
# =========================
ENVIRONMENT=development

# =========================
# Processing
# =========================
PROCESSING_MODE=local
WORKER_POLL_SECONDS=1

# =========================
# Database
# =========================
DATABASE_URL=sqlite:///./data/docuguardian.db
REDIS_URL=redis://localhost:6379/0

# =========================
# Object Storage
# =========================
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=docuguardian
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
STORAGE_MODE=local

# =========================
# Antivirus
# =========================
CLAMAV_URL=

# =========================
# Upload Limit (25 MB)
# =========================
MAX_UPLOAD_BYTES=26214400

# =========================
# Authentication
# =========================
AUTH_SECRET=docuguardian-local-development-secret-change-before-production
ENABLE_DEMO_AUTH=true

# =========================
# AI
# =========================
ENABLE_FIXTURE_ANALYSIS=false
AI_MODE=real
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# =========================
# Features
# =========================
# Leave blank to enable automatically when OPENAI_API_KEY is configured.
# Set either value to false to explicitly disable it.
FEATURE_VOICE=
FEATURE_TRANSLATION=
FEATURE_FRAUD=false
FEATURE_EXTERNAL_CALENDAR=false

# External calendar OAuth (requires FEATURE_EXTERNAL_CALENDAR=true)
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/calendar/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/integrations/calendar/outlook/callback

# =========================
# Supported Languages
# =========================
SUPPORTED_LANGUAGES=English,Spanish,Hindi,French,German,Arabic,Portuguese,Chinese (Simplified),Japanese,Marathi,Tamil

# =========================
# Email Notifications
# =========================
SMTP_URL=
NOTIFICATION_FROM=noreply@docuguardian.local
