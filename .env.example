# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Local data directory for SQLite DB and uploads
DOCUGUARDIAN_DATA_DIR=./data

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# App environment: development | production
ENVIRONMENT=development

# local = FastAPI background tasks, worker = compose/database worker
PROCESSING_MODE=local
WORKER_POLL_SECONDS=1

# Database
DATABASE_URL=sqlite:///./data/docuguardian.db
REDIS_URL=redis://localhost:6379/0

# Object storage (compose / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=docuguardian
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
STORAGE_MODE=local

# Optional antivirus scan endpoint
CLAMAV_URL=

# Upload limit in bytes (default 25 MB)
MAX_UPLOAD_BYTES=26214400

# Auth
AUTH_SECRET=replace-with-a-long-random-secret
ENABLE_DEMO_AUTH=true

# AI pipeline
ENABLE_FIXTURE_ANALYSIS=false
AI_MODE=real
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# Product feature flags
# Set both to true to expose translation + voice in the UI
FEATURE_VOICE=false
FEATURE_TRANSLATION=false

# Languages shown in Settings and AI Chat selectors
SUPPORTED_LANGUAGES=English,Spanish,Hindi,French,German,Arabic,Portuguese,Chinese (Simplified),Japanese,Marathi,Tamil

# Optional reminder email delivery
SMTP_URL=
NOTIFICATION_FROM=noreply@docuguardian.local
